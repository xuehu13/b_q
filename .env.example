ENV=testnet
RUN_MODE=backtest
TESTNET=true

BINANCE_API_KEY=
BINANCE_API_SECRET=

SYMBOL=BTCUSDT
KLINE_INTERVAL=1s

MA_SHORT_WINDOW=5
MA_LONG_WINDOW=20

ORDER_NOTIONAL_USDT=50
MAX_POSITION_QTY=0.01
MAX_TRADES_PER_MINUTE=1
MAX_DAILY_LOSS_USDT=100
MAX_CONSECUTIVE_LOSSES=3

TAKER_FEE_RATE=0.001
MAKER_FEE_RATE=0.001

HISTORY_DAYS=7
PRELOAD_BARS=200

ENABLE_TRADE_STREAM=false
ENABLE_AUTO_TRADING=false

LOG_LEVEL=INFO
